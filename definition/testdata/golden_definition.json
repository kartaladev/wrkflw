{
  "id": "golden",
  "version": 7,
  "nodes": [
    {
      "id": "start",
      "kind": "startEvent",
      "name": "Start",
      "timerTrigger": {
        "kind": "expr",
        "expr": "1h"
      },
      "signalName": "go",
      "messageName": "kickoff",
      "correlationKey": "orderId"
    },
    {
      "id": "charge",
      "kind": "serviceTask",
      "name": "Charge",
      "action": "charge-card",
      "deadlineTrigger": {
        "kind": "expr",
        "expr": "2h"
      },
      "waitTrigger": {
        "kind": "everyExpr",
        "expr": "30m"
      },
      "deadlineFlow": "sla-flow",
      "deadlineAction": "notify-ops",
      "waitAction": "ping",
      "retryPolicy": {
        "MaxAttempts": 5,
        "InitialInterval": 2000000000,
        "BackoffCoef": 2,
        "MaxInterval": 90000000000,
        "MaxElapsed": 600000000000,
        "NonRetryableErrors": [
          "fatal",
          "denied"
        ]
      },
      "recoveryFlow": "charge-\u003efallback",
      "compensateAction": "refund-card",
      "cancelAction": "abort-charge"
    },
    {
      "id": "approve",
      "kind": "userTask",
      "name": "Approve",
      "eligibleRoles": [
        "manager",
        "director"
      ],
      "eligiblePrivileges": [
        "finance-task claim",
        "finance-task complete"
      ],
      "eligibleExpr": "vars[\"region\"] == \"EU\""
    },
    {
      "id": "await",
      "kind": "receiveTask",
      "name": "Await Payment",
      "messageName": "payment-confirmed",
      "correlationKey": "orderId"
    },
    {
      "id": "notify",
      "kind": "sendTask",
      "name": "Notify",
      "messageName": "shipment-ready",
      "correlationKey": "orderId"
    },
    {
      "id": "score",
      "kind": "businessRuleTask",
      "name": "Score",
      "action": "risk-score"
    },
    {
      "id": "packing",
      "kind": "subProcess",
      "name": "Packing",
      "subprocess": {
        "id": "sub",
        "version": 1,
        "nodes": [
          {
            "id": "sub-start",
            "kind": "startEvent"
          },
          {
            "id": "sub-end",
            "kind": "endEvent"
          }
        ],
        "flows": [
          {
            "ID": "sf1",
            "Source": "sub-start",
            "Target": "sub-end",
            "Condition": "",
            "IsDefault": false
          }
        ]
      }
    },
    {
      "id": "fulfil",
      "kind": "callActivity",
      "name": "Fulfil",
      "defRef": "fulfilment-def"
    },
    {
      "id": "compensator",
      "kind": "subProcess",
      "name": "Compensator",
      "subprocess": {
        "id": "sub",
        "version": 1,
        "nodes": [
          {
            "id": "sub-start",
            "kind": "startEvent",
            "signalName": "recover",
            "nonInterrupting": true
          },
          {
            "id": "sub-end",
            "kind": "endEvent"
          }
        ],
        "flows": [
          {
            "ID": "sf1",
            "Source": "sub-start",
            "Target": "sub-end",
            "Condition": "",
            "IsDefault": false
          }
        ]
      }
    },
    {
      "id": "wait",
      "kind": "intermediateCatchEvent",
      "name": "Wait",
      "timerTrigger": {
        "kind": "expr",
        "expr": "15m"
      },
      "deadlineTrigger": {
        "kind": "expr",
        "expr": "4h"
      },
      "waitTrigger": {
        "kind": "everyExpr",
        "expr": "1h"
      },
      "deadlineFlow": "wait-\u003eesc",
      "deadlineAction": "escalate",
      "waitAction": "nudge",
      "signalName": "resume",
      "messageName": "go-on",
      "correlationKey": "orderId"
    },
    {
      "id": "emit",
      "kind": "intermediateThrowEvent",
      "name": "Emit",
      "signalName": "done"
    },
    {
      "id": "compensate",
      "kind": "compensationThrowEvent",
      "name": "Compensate",
      "compensateRef": "charge"
    },
    {
      "id": "timeout",
      "kind": "boundaryEvent",
      "name": "Timeout",
      "timerTrigger": {
        "kind": "expr",
        "expr": "5m"
      },
      "signalName": "abort",
      "messageName": "cancel",
      "correlationKey": "orderId",
      "errorCode": "E_TIMEOUT",
      "attachedTo": "charge",
      "nonInterrupting": true
    },
    {
      "id": "xor",
      "kind": "exclusiveGateway",
      "name": "XOR"
    },
    {
      "id": "and",
      "kind": "parallelGateway",
      "name": "AND"
    },
    {
      "id": "or",
      "kind": "inclusiveGateway",
      "name": "OR"
    },
    {
      "id": "race",
      "kind": "eventBasedGateway",
      "name": "RACE"
    },
    {
      "id": "kill",
      "kind": "endEvent",
      "name": "Kill",
      "endBehavior": "terminate",
      "terminationReason": "operator-initiated kill",
      "terminationOutcome": "abort"
    },
    {
      "id": "boom",
      "kind": "endEvent",
      "name": "Boom",
      "errorCode": "E_BOOM",
      "endBehavior": "error"
    },
    {
      "id": "end",
      "kind": "endEvent",
      "name": "End"
    }
  ],
  "flows": [
    {
      "ID": "f1",
      "Source": "start",
      "Target": "charge",
      "Condition": "",
      "IsDefault": false
    },
    {
      "ID": "f2",
      "Source": "charge",
      "Target": "xor",
      "Condition": "",
      "IsDefault": false
    },
    {
      "ID": "f3",
      "Source": "xor",
      "Target": "approve",
      "Condition": "amount \u003e 100",
      "IsDefault": false
    },
    {
      "ID": "f4",
      "Source": "xor",
      "Target": "end",
      "Condition": "",
      "IsDefault": true
    }
  ],
  "cancelActions": [
    "cancel-a",
    "cancel-b"
  ]
}
